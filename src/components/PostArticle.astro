---
import { BLOG_AUTHOR, getCategoryLabel } from '../config/blog';
import { DEFAULT_LANG, UI, type Lang } from '../i18n/ui';
import { formatPostDate, getPostCategory, getPostLang, getPostSlug, type BlogPost } from '../lib/blog';

interface Props {
	post: BlogPost;
	lang?: Lang;
}

const { post, lang = DEFAULT_LANG } = Astro.props;
const t = UI[lang];
const category = getPostCategory(post);
// CMS는 ko 폴더만 관리하므로 ko 글은 Sveltia로, en 글은 GitHub 파일 편집으로 연결한다.
const encodedSlug = getPostSlug(post).split('/').map(encodeURIComponent).join('/');
const writerEditUrl = `/admin/write.html?edit=${encodedSlug}`;
const editUrl =
	getPostLang(post) === 'en' && post.filePath
		? `https://github.com/eddie484/eddie484.github.io/edit/main/${post.filePath}`
		: writerEditUrl;
---

<article class="post-article">
	<header class="post-article__header">
		<div class="post-category">{category ? getCategoryLabel(category, lang) : t.categoryFallback}</div>
		<h1>{post.data.title}</h1>
		<div class="post-meta-row">
			<div class="post-meta">
				<span class="post-author">{BLOG_AUTHOR}</span>
				<time datetime={post.data.pubDate.toISOString()}>{formatPostDate(post.data.pubDate, lang)}</time>
			</div>
			<div class="post-actions" aria-label={t.postActionsAria}>
				<button
					class="post-action-button"
					type="button"
					data-copy-url
					data-label-copied={t.copied}
					data-label-failed={t.copyFailed}>{t.copyUrl}</button
				>
				<div class="post-admin-menu" data-admin-only data-post-menu hidden>
					<button
						class="post-menu-toggle"
						type="button"
						aria-label={t.postMenuAria}
						aria-expanded="false"
						data-post-menu-toggle
					>
						⋮
					</button>
					<div class="post-menu-panel" data-post-menu-panel hidden>
						<a class="post-menu-item" href={editUrl}>{t.edit}</a>
					</div>
				</div>
			</div>
		</div>
	</header>
	<div class="post-body">
		<slot />
	</div>
</article>

<script is:inline>
	(() => {
		async function copyWithFallback(text) {
			if (navigator.clipboard?.writeText) {
				try {
					await navigator.clipboard.writeText(text);
					return;
				} catch {
					// Fall back to the textarea method below.
				}
			}

			const textarea = document.createElement('textarea');
			textarea.value = text;
			textarea.setAttribute('readonly', '');
			textarea.style.position = 'fixed';
			textarea.style.top = '-999px';
			document.body.append(textarea);
			textarea.select();

			const copied = document.execCommand('copy');
			textarea.remove();

			if (!copied) {
				throw new Error('Copy failed');
			}
		}

		document.querySelectorAll('[data-copy-url]').forEach((button) => {
			const defaultLabel = button.textContent;
			let resetTimer;

			button.addEventListener('click', async () => {
				window.clearTimeout(resetTimer);
				button.textContent = button.dataset.labelCopied;
				resetTimer = window.setTimeout(() => {
					button.textContent = defaultLabel;
				}, 1400);

				try {
					await copyWithFallback(window.location.href);
				} catch {
					window.clearTimeout(resetTimer);
					button.textContent = button.dataset.labelFailed;
					resetTimer = window.setTimeout(() => {
						button.textContent = defaultLabel;
					}, 1400);
				}
			});
		});

		document.querySelectorAll('[data-post-menu]').forEach((menu) => {
			const toggle = menu.querySelector('[data-post-menu-toggle]');
			const panel = menu.querySelector('[data-post-menu-panel]');

			if (!toggle || !panel) {
				return;
			}

			function closeMenu() {
				panel.hidden = true;
				toggle.setAttribute('aria-expanded', 'false');
			}

			toggle.addEventListener('click', (event) => {
				event.stopPropagation();
				const shouldOpen = panel.hidden;

				document.querySelectorAll('[data-post-menu-panel]').forEach((otherPanel) => {
					otherPanel.hidden = true;
				});

				panel.hidden = !shouldOpen;
				toggle.setAttribute('aria-expanded', String(shouldOpen));
			});

			panel.addEventListener('click', (event) => {
				event.stopPropagation();
			});

			document.addEventListener('click', closeMenu);
			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeMenu();
				}
			});
		});
	})();
</script>

<style>
	.post-article__header {
		padding-bottom: 22px;
		border-bottom: 1px solid var(--line);
	}

	.post-category {
		margin-bottom: 22px;
		color: var(--muted);
		font-size: 14px;
	}

	.post-article h1 {
		margin: 0 0 24px;
		color: var(--ink);
		font-size: 30px;
		font-weight: 500;
		line-height: 1.45;
	}

	.post-meta-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		min-height: 32px;
	}

	.post-meta {
		display: flex;
		gap: 8px;
		align-items: center;
		color: var(--muted);
		font-size: 13px;
	}

	.post-author {
		color: var(--ink);
		font-weight: 700;
	}

	.post-actions {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-left: auto;
	}

	.post-action-button,
	.post-menu-toggle {
		border: 0;
		background: transparent;
		color: var(--muted);
		font: inherit;
		font-size: 13px;
		font-weight: 700;
		cursor: pointer;
	}

	.post-action-button {
		min-width: 56px;
		padding: 4px 0;
		text-align: center;
	}

	.post-menu-toggle {
		width: 28px;
		height: 28px;
		padding: 0;
		font-size: 24px;
		line-height: 24px;
	}

	.post-action-button:hover,
	.post-menu-toggle:hover,
	.post-menu-toggle[aria-expanded='true'] {
		color: var(--accent);
	}

	.post-action-button:focus-visible,
	.post-menu-toggle:focus-visible,
	.post-menu-item:focus-visible {
		outline: 1px solid var(--accent);
		outline-offset: 2px;
	}

	.post-admin-menu {
		position: relative;
	}

	.post-admin-menu[hidden],
	.post-menu-panel[hidden] {
		display: none !important;
	}

	.post-menu-panel {
		position: absolute;
		top: 34px;
		right: 0;
		z-index: 10;
		width: 154px;
		border: 1px solid var(--line-strong);
		border-radius: 3px;
		background: var(--surface);
		box-shadow: 0 8px 20px rgba(36, 50, 57, 0.12);
	}

	.post-menu-item {
		display: block;
		padding: 11px 15px;
		color: var(--side-ink);
		font-size: 14px;
		font-weight: 500;
		line-height: 1.4;
		text-decoration: none;
	}

	.post-menu-item:hover {
		background: var(--surface-soft);
		color: var(--accent);
	}

	.post-body {
		padding-top: 34px;
		color: var(--body);
		font-size: 15px;
		line-height: 1.9;
	}

	.post-body :global(p) {
		margin: 0 0 1.4em;
	}

	.post-body :global(h1),
	.post-body :global(h2),
	.post-body :global(h3),
	.post-body :global(h4) {
		margin: 2em 0 0.7em;
		color: var(--ink);
		line-height: 1.35;
	}

	.post-body :global(h2) {
		font-size: 22px;
	}

	.post-body :global(h3) {
		font-size: 18px;
	}

	.post-body :global(a) {
		color: var(--accent);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}

	.post-body :global(img) {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 28px auto;
		border-radius: 2px;
	}

	.post-body :global(pre) {
		overflow-x: auto;
		padding: 16px;
		border: 1px solid var(--line);
		border-radius: 4px;
		background: var(--surface-strong);
	}

	.post-body :global(code) {
		padding: 2px 5px;
		border-radius: 3px;
		background: var(--surface-strong);
	}

	.post-body :global(pre code) {
		padding: 0;
		background: transparent;
	}
</style>
