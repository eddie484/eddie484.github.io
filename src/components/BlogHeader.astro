---
import { BANNER, BLOG_TITLE, EXTERNAL_NAV, PRIMARY_NAV } from '../config/blog';
import { DEFAULT_LANG, otherLang, UI, type Lang } from '../i18n/ui';
import { getCategoryById, getCategoryUrl } from '../lib/blog';

interface Props {
	lang?: Lang;
	// 언어 토글이 이동할 반대 언어 URL. 없으면 반대 언어 블로그 홈으로 보낸다.
	altUrl?: string;
}

const { lang = DEFAULT_LANG, altUrl } = Astro.props;
const t = UI[lang];
const nextLang = otherLang(lang);
const toggleHref = altUrl ?? `/${nextLang}/blog/`;

const currentPath = Astro.url.pathname;

function resolveHref(item: (typeof PRIMARY_NAV)[number]) {
	if ('href' in item) {
		return `/${lang}${item.href}`;
	}

	const category = getCategoryById(item.categoryId);
	return category ? getCategoryUrl(category, lang) : `/${lang}/blog/`;
}

function isActive(href: string) {
	return currentPath === href || currentPath.startsWith(href);
}

const bannerStyle = BANNER.image
	? `background-image: linear-gradient(rgba(255,255,255,.64), rgba(255,255,255,.64)), url('${BANNER.image}');`
	: `background-color: ${BANNER.backgroundColor};`;
---

<header class="blog-header">
	<div class="admin-bar" aria-label={t.adminMenuAria}>
		<nav class="lang-toggle" aria-label={t.langToggleAria}>
			<span class:list={{ active: lang === 'ko' }}>
				{lang === 'ko' ? 'KO' : <a href={toggleHref}>KO</a>}
			</span>
			<span aria-hidden="true">·</span>
			<span class:list={{ active: lang === 'en' }}>
				{lang === 'en' ? 'EN' : <a href={toggleHref}>EN</a>}
			</span>
		</nav>
		<button
			class="admin-toggle"
			type="button"
			data-admin-toggle
			data-label-login={t.login}
			data-label-logout={t.logout}
			aria-pressed="false">{t.login}</button
		>
	</div>
	<a
		class="blog-banner"
		href={`/${lang}/blog/`}
		style={bannerStyle}
		aria-label={t.goToMain(BLOG_TITLE[lang])}
	>
		<span>{BLOG_TITLE[lang]}</span>
	</a>
	<nav class="blog-nav" aria-label={t.topMenuAria}>
		<div class="blog-nav__group">
			{
				PRIMARY_NAV.map((item) => {
					const href = resolveHref(item);
					return (
						<a href={href} class:list={{ active: isActive(href) }}>
							{item.label[lang]}
						</a>
					);
				})
			}
		</div>
		<div class="blog-nav__group blog-nav__group--external">
			<a
				href={`/${lang}/tools/first-follow/`}
				class:list={{ active: isActive(`/${lang}/tools/first-follow/`) }}
			>
				{t.firstFollowNav}
			</a>
			{EXTERNAL_NAV.map((item) => <a href={item.href} target="_blank">{item.label}</a>)}
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const storageKey = 'blog:admin-mode';
		const toggle = document.querySelector('[data-admin-toggle]');

		function readAdminMode() {
			try {
				return localStorage.getItem(storageKey) === 'true';
			} catch {
				return false;
			}
		}

		function writeAdminMode(isAdmin) {
			try {
				if (isAdmin) {
					localStorage.setItem(storageKey, 'true');
				} else {
					localStorage.removeItem(storageKey);
				}
			} catch {
				// This is only a convenience toggle, so storage failures can fail quietly.
			}
		}

		function applyAdminMode(isAdmin) {
			document.documentElement.classList.toggle('admin-mode', isAdmin);
			document.body?.classList.toggle('admin-mode', isAdmin);

			document.querySelectorAll('[data-admin-only]').forEach((item) => {
				item.hidden = !isAdmin;
			});

			if (toggle) {
				toggle.textContent = isAdmin ? toggle.dataset.labelLogout : toggle.dataset.labelLogin;
				toggle.setAttribute('aria-pressed', String(isAdmin));
			}
		}

		applyAdminMode(readAdminMode());
		document.addEventListener('DOMContentLoaded', () => {
			applyAdminMode(readAdminMode());
		});

		toggle?.addEventListener('click', () => {
			const nextAdminMode = !readAdminMode();
			writeAdminMode(nextAdminMode);
			applyAdminMode(nextAdminMode);
		});
	})();
</script>

<style>
	.blog-header {
		position: relative;
		width: var(--site-width);
		min-width: var(--site-width);
		margin: 0 auto;
	}

	.admin-bar {
		position: absolute;
		top: -24px;
		right: 0;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 10px;
	}

	.lang-toggle {
		display: flex;
		align-items: center;
		gap: 5px;
		color: var(--muted-light);
		font-size: 12px;
		font-weight: 700;
		line-height: 20px;
	}

	.lang-toggle a {
		color: var(--muted);
		text-decoration: none;
	}

	.lang-toggle a:hover {
		color: var(--accent);
	}

	.lang-toggle .active {
		color: var(--accent);
	}

	.admin-toggle {
		height: 22px;
		padding: 0 8px;
		border: 1px solid transparent;
		background: transparent;
		color: var(--muted);
		font: inherit;
		font-size: 12px;
		font-weight: 700;
		line-height: 20px;
		cursor: pointer;
	}

	.admin-toggle:hover,
	.admin-toggle[aria-pressed='true'] {
		color: var(--accent);
	}

	.admin-toggle:focus-visible {
		border-color: var(--accent);
		outline: 0;
	}

	.blog-banner {
		display: flex;
		align-items: center;
		min-height: 178px;
		padding: 26px 34px;
		background-position: center;
		background-size: cover;
		border: 1px solid var(--line);
		border-bottom: 0;
		color: var(--ink);
		text-decoration: none;
	}

	.blog-banner span {
		font-size: 30px;
		font-weight: 700;
		letter-spacing: 0;
	}

	.blog-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 42px;
		padding: 0 18px;
		background: var(--surface);
		border: 1px solid var(--line);
	}

	.blog-nav__group {
		display: flex;
		align-items: center;
		gap: 18px;
	}

	.blog-nav a {
		color: var(--muted);
		font-size: 13px;
		font-weight: 700;
		text-decoration: none;
	}

	.blog-nav a:hover,
	.blog-nav a.active {
		color: var(--accent);
	}

	.blog-nav__group--external a {
		font-weight: 600;
	}
</style>
