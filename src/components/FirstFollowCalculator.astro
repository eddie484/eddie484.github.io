---
import type { Lang } from '../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;

const copy = {
	ko: {
		grammar: '문법 입력',
		sample: '샘플',
		clear: '지우기',
		calculate: '계산',
		result: '계산 결과',
		copy: '복사',
		setFormat: '집합 형식',
		cFormat: 'C 함수 형식',
		compare: 'FIRST/FOLLOW 비교',
		versionA: '버전 A',
		versionB: '버전 B',
		compareAction: '비교',
	},
	en: {
		grammar: 'Grammar input',
		sample: 'Sample',
		clear: 'Clear',
		calculate: 'Calculate',
		result: 'Results',
		copy: 'Copy',
		setFormat: 'Set format',
		cFormat: 'C function format',
		compare: 'Compare FIRST/FOLLOW',
		versionA: 'Version A',
		versionB: 'Version B',
		compareAction: 'Compare',
	},
} as const;

const t = copy[lang];
---

<div class="first-follow-calculator" data-first-follow>
	<section class="workspace" aria-label={t.grammar}>
		<div class="panel panel-input">
			<div class="panel-head">
				<div>
					<p class="eyebrow">Grammar</p>
					<h2>{t.grammar}</h2>
				</div>
				<div class="actions">
					<button type="button" id="load-sample">{t.sample}</button>
					<button type="button" id="clear-grammar">{t.clear}</button>
					<button class="primary" type="button" id="calculate">{t.calculate}</button>
				</div>
			</div>
			<label class="field">
				<span>{t.grammar}</span>
				<textarea id="grammar-input" spellcheck="false"></textarea>
			</label>
		</div>

		<div class="panel panel-output">
			<div class="panel-head compact">
				<div>
					<p class="eyebrow">Result</p>
					<h2>{t.result}</h2>
				</div>
				<button type="button" id="copy-result">{t.copy}</button>
			</div>
			<div id="messages" class="messages" aria-live="polite"></div>
			<div class="output-stack">
				<div class="field">
					<span>{t.setFormat}</span>
					<pre id="result-output" class="result-box" tabindex="0"></pre>
				</div>
				<div class="field">
					<span>{t.cFormat}</span>
					<pre id="code-output" class="result-box" tabindex="0"></pre>
				</div>
			</div>
		</div>
	</section>

	<section class="compare" aria-labelledby="compare-title">
		<div class="panel">
			<div class="panel-head">
				<div>
					<p class="eyebrow">Diff</p>
					<h2 id="compare-title">{t.compare}</h2>
				</div>
				<div class="actions">
					<button type="button" id="clear-compare">{t.clear}</button>
					<button class="primary" type="button" id="compare-button">{t.compareAction}</button>
				</div>
			</div>
			<div class="compare-grid">
				<label class="field">
					<span>{t.versionA}</span>
					<textarea id="ff-left" spellcheck="false"></textarea>
				</label>
				<label class="field">
					<span>{t.versionB}</span>
					<textarea id="ff-right" spellcheck="false"></textarea>
				</label>
			</div>
			<div id="diff-output" class="diff-output" aria-live="polite"></div>
		</div>
	</section>
</div>

<script is:inline src="/tools/first-follow/app.js" defer></script>

<style is:global>
	.first-follow-calculator {
		--ff-code: #172033;
		--ff-code-bg: #f8fafc;
		--ff-warn: #a16207;
		--ff-danger: #b42318;
		--ff-added: #e7f7ee;
		--ff-removed: #fff0ed;
		--ff-changed: #fff8dc;
	}

	.first-follow-calculator *,
	.first-follow-calculator *::before,
	.first-follow-calculator *::after {
		box-sizing: border-box;
	}

	.first-follow-calculator button,
	.first-follow-calculator textarea {
		font: inherit;
	}

	.first-follow-calculator button {
		min-height: 38px;
		padding: 0 14px;
		border: 1px solid var(--line-strong);
		border-radius: 3px;
		background: var(--surface);
		color: var(--ink);
		cursor: pointer;
		transition:
			border-color 120ms ease,
			background 120ms ease,
			transform 120ms ease;
	}

	.first-follow-calculator button:hover {
		border-color: var(--accent);
	}

	.first-follow-calculator button:focus-visible,
	.first-follow-calculator textarea:focus-visible,
	.first-follow-calculator pre:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.first-follow-calculator button:active {
		transform: translateY(1px);
	}

	.first-follow-calculator button.primary {
		border-color: var(--accent);
		background: var(--accent);
		color: #fff;
	}

	.first-follow-calculator .workspace {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
		gap: 18px;
		align-items: stretch;
	}

	.first-follow-calculator .compare {
		margin-top: 18px;
	}

	.first-follow-calculator .panel {
		padding: 18px;
		border: 1px solid var(--line);
		background: var(--surface);
	}

	.first-follow-calculator .panel-input,
	.first-follow-calculator .panel-output {
		min-height: 720px;
	}

	.first-follow-calculator .panel-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 14px;
		margin-bottom: 14px;
	}

	.first-follow-calculator .panel-head.compact {
		align-items: center;
	}

	.first-follow-calculator .actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 8px;
	}

	.first-follow-calculator .eyebrow {
		margin: 0 0 3px;
		color: var(--accent);
		font-size: 12px;
		font-weight: 700;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.first-follow-calculator h2 {
		margin: 0;
		color: var(--ink);
		font-size: 20px;
		font-weight: 700;
		line-height: 1.25;
	}

	.first-follow-calculator .field {
		display: grid;
		min-width: 0;
		gap: 8px;
	}

	.first-follow-calculator .field > span {
		color: var(--muted);
		font-size: 13px;
		font-weight: 700;
	}

	.first-follow-calculator textarea,
	.first-follow-calculator .result-box {
		width: 100%;
		border: 1px solid var(--line);
		border-radius: 3px;
		background: var(--ff-code-bg);
		color: var(--ff-code);
		font-family: 'Cascadia Code', Consolas, monospace;
		font-size: 13px;
		line-height: 1.55;
		tab-size: 2;
	}

	.first-follow-calculator textarea {
		min-height: 620px;
		padding: 14px;
		resize: vertical;
	}

	.first-follow-calculator .panel-output {
		display: grid;
		grid-template-rows: auto auto minmax(0, 1fr);
	}

	.first-follow-calculator .output-stack {
		display: grid;
		min-height: 0;
		gap: 14px;
	}

	.first-follow-calculator .result-box {
		min-height: 292px;
		margin: 0;
		padding: 14px;
		overflow: auto;
		white-space: pre-wrap;
	}

	.first-follow-calculator .messages {
		min-height: 28px;
		color: var(--muted);
		font-size: 13px;
	}

	.first-follow-calculator .messages.error {
		color: var(--ff-danger);
	}

	.first-follow-calculator .compare-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.first-follow-calculator .compare-grid textarea {
		min-height: 300px;
	}

	.first-follow-calculator .diff-output {
		display: grid;
		margin-top: 14px;
		gap: 10px;
	}

	.first-follow-calculator .diff-summary {
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 3px;
		background: var(--surface);
	}

	.first-follow-calculator .diff-row {
		display: grid;
		grid-template-columns: minmax(190px, 0.8fr) minmax(0, 1fr) minmax(0, 1fr);
		border-top: 1px solid var(--line);
	}

	.first-follow-calculator .diff-row:first-child {
		border-top: 0;
	}

	.first-follow-calculator .diff-cell {
		min-width: 0;
		padding: 10px 12px;
	}

	.first-follow-calculator .diff-cell + .diff-cell {
		border-left: 1px solid var(--line);
	}

	.first-follow-calculator .diff-key {
		color: var(--ff-code);
		font-family: 'Cascadia Code', Consolas, monospace;
		font-size: 13px;
	}

	.first-follow-calculator .token-list {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.first-follow-calculator .token {
		display: inline-flex;
		min-height: 24px;
		align-items: center;
		padding: 1px 8px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--surface);
		font-family: 'Cascadia Code', Consolas, monospace;
		font-size: 12px;
	}

	.first-follow-calculator .token.added {
		border-color: #a7dbc0;
		background: var(--ff-added);
	}

	.first-follow-calculator .token.removed {
		border-color: #f4b8ad;
		background: var(--ff-removed);
	}

	.first-follow-calculator .status-line {
		padding: 12px;
		border: 1px solid var(--line);
		border-radius: 3px;
		background: var(--surface);
		color: var(--muted);
	}

	.first-follow-calculator .status-line.warn {
		border-color: #e7c66b;
		background: var(--ff-changed);
		color: var(--ff-warn);
	}

	@media (max-width: 980px) {
		.first-follow-calculator .workspace,
		.first-follow-calculator .compare-grid {
			grid-template-columns: 1fr;
		}

		.first-follow-calculator .panel-input,
		.first-follow-calculator .panel-output {
			min-height: auto;
		}

		.first-follow-calculator textarea,
		.first-follow-calculator .result-box {
			min-height: 360px;
		}
	}

	@media (max-width: 640px) {
		.first-follow-calculator .panel {
			padding: 12px;
		}

		.first-follow-calculator .panel-head {
			align-items: stretch;
			flex-direction: column;
		}

		.first-follow-calculator .actions {
			justify-content: stretch;
		}

		.first-follow-calculator .actions button,
		.first-follow-calculator .panel-head > button {
			flex: 1 1 0;
		}

		.first-follow-calculator .diff-row {
			grid-template-columns: 1fr;
		}

		.first-follow-calculator .diff-cell + .diff-cell {
			border-top: 1px solid var(--line);
			border-left: 0;
		}
	}
</style>
