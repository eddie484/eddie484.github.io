---
import {
	formatPostDate,
	getAdjacentWindow,
	getCategoryUrl,
	getPostCategory,
	getPostUrl,
	type BlogPost,
} from '../lib/blog';

interface Props {
	posts: BlogPost[];
	currentPost: BlogPost;
}

const { posts, currentPost } = Astro.props;
const currentCategory = getPostCategory(currentPost);
const { items, newerPost, olderPost } = getAdjacentWindow(posts, currentPost);
const scopeUrl = currentCategory ? getCategoryUrl(currentCategory) : '/blog/';
---

<section class="post-footer-list" aria-label="현재 카테고리의 다른 글">
	<header>
		<strong>{currentCategory?.label ?? '이 카테고리'}의 글</strong>
		<a href={scopeUrl}>전체글 보기</a>
	</header>
	<div class="footer-list-rows">
		{
			items.map((post) => (
				<a href={getPostUrl(post)} class:list={['footer-list-row', { active: post.id === currentPost.id }]}>
					<span>{post.data.title}</span>
					<time datetime={post.data.pubDate.toISOString()}>{formatPostDate(post.data.pubDate)}</time>
				</a>
			))
		}
	</div>
	<nav class="footer-list-nav" aria-label="이전 다음 글">
		{
			newerPost ? (
				<a href={getPostUrl(newerPost)}>‹ 이전</a>
			) : (
				<span class="disabled">‹ 이전</span>
			)
		}
		{
			olderPost ? (
				<a href={getPostUrl(olderPost)}>다음 ›</a>
			) : (
				<span class="disabled">다음 ›</span>
			)
		}
	</nav>
</section>

<style>
	.post-footer-list {
		margin-top: 58px;
		padding-top: 22px;
		border-top: 1px solid var(--line);
	}

	.post-footer-list header {
		display: flex;
		justify-content: space-between;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--line-strong);
		color: var(--ink);
		font-size: 13px;
	}

	.post-footer-list header a {
		color: var(--muted);
		text-decoration: none;
	}

	.post-footer-list header a:hover {
		color: var(--accent);
	}

	.footer-list-row {
		display: grid;
		grid-template-columns: 1fr 136px;
		gap: 20px;
		min-height: 32px;
		align-items: center;
		border-bottom: 1px solid var(--line);
		color: var(--ink);
		font-size: 13px;
		text-decoration: none;
	}

	.footer-list-row:hover,
	.footer-list-row.active {
		color: var(--accent);
		font-weight: 700;
	}

	.footer-list-row time {
		color: var(--muted);
		text-align: right;
		font-weight: 400;
	}

	.footer-list-nav {
		display: flex;
		justify-content: center;
		gap: 28px;
		padding-top: 16px;
		font-size: 13px;
	}

	.footer-list-nav a {
		color: var(--ink);
		text-decoration: none;
	}

	.footer-list-nav a:hover {
		color: var(--accent);
	}

	.footer-list-nav .disabled {
		color: var(--muted-light);
	}
</style>
