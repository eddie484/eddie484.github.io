---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { DEFAULT_LANG, otherLang, type Lang } from '../i18n/ui';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	lang?: Lang;
	// 이 페이지와 내용이 대응되는 반대 언어 페이지의 경로. 있으면 hreflang을 내보낸다.
	translationUrl?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, lang = DEFAULT_LANG, translationUrl } = Astro.props;
const altLang = otherLang(lang);
const ogLocale = lang === 'ko' ? 'ko_KR' : 'en_US';
const altOgLocale = lang === 'ko' ? 'en_US' : 'ko_KR';
const translationURL = translationUrl ? new URL(translationUrl, Astro.site) : undefined;
const defaultLangURL = lang === DEFAULT_LANG ? canonicalURL : translationURL;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE[lang]}
	href={new URL(`${lang}/rss.xml`, Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Language alternates -->
{
	translationURL && (
		<>
			<link rel="alternate" hreflang={lang} href={canonicalURL} />
			<link rel="alternate" hreflang={altLang} href={translationURL} />
			{defaultLangURL && <link rel="alternate" hreflang="x-default" href={defaultLangURL} />}
		</>
	)
}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />
<meta property="og:locale" content={ogLocale} />
{translationURL && <meta property="og:locale:alternate" content={altOgLocale} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />
