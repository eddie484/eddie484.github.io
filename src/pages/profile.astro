---
import BaseHead from '../components/BaseHead.astro';
import BlogHeader from '../components/BlogHeader.astro';
import { BLOG_DESCRIPTION, BLOG_TITLE } from '../config/blog';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`프로필 | ${BLOG_TITLE}`} description={BLOG_DESCRIPTION} />
	</head>
	<body>
		<BlogHeader />
		<main class="profile-shell">
			<h1>프로필</h1>
			<p>이 공간은 나중에 정리합니다.</p>
		</main>
	</body>
</html>

<style>
	.profile-shell {
		width: var(--site-width);
		min-width: var(--site-width);
		margin: 22px auto 80px;
		padding: 40px;
		border: 1px solid var(--line);
		background: var(--surface);
	}

	.profile-shell h1 {
		margin: 0 0 12px;
		font-size: 26px;
	}

	.profile-shell p {
		margin: 0;
		color: var(--muted);
		font-size: 14px;
	}
</style>
