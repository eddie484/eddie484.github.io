---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getLatestPost, sortPosts } from '../../lib/blog';

const allPosts = sortPosts(await getCollection('blog'));
const currentPost = getLatestPost(allPosts);
const { Content } = currentPost ? await render(currentPost) : { Content: undefined };
---

<BlogLayout
	allPosts={allPosts}
	scopePosts={allPosts}
	scopeTitle="전체보기"
	currentPost={currentPost}
	content={Content}
/>
