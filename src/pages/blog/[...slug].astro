---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getPostScopePosts, getPostScopeTitle, sortPosts } from '../../lib/blog';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const currentPost = Astro.props;
const allPosts = sortPosts(await getCollection('blog'));
const scopePosts = getPostScopePosts(allPosts, currentPost);
const scopeTitle = getPostScopeTitle(currentPost);
const { Content } = await render(currentPost);
---

<BlogLayout
	allPosts={allPosts}
	scopePosts={scopePosts}
	scopeTitle={scopeTitle}
	currentPost={currentPost}
	activeCategoryId={currentPost.data.category}
	content={Content}
/>
