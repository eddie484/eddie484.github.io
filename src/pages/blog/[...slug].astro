---
import { getCollection } from 'astro:content';
import { UI } from '../../i18n/ui';
import RedirectPage from '../../layouts/RedirectPage.astro';
import { getPostLang, getPostSlug, getPostUrl } from '../../lib/blog';

// 언어 분리 이전의 /blog/[slug]/ URL을 /ko/blog/[slug]/로 넘긴다.
export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((post) => getPostLang(post) === 'ko')
		.map((post) => ({
			params: { slug: getPostSlug(post) },
			props: { to: getPostUrl(post), title: post.data.title },
		}));
}

const { to, title } = Astro.props;
---

<RedirectPage to={to} title={title} message={UI.ko.goToBlog} />
