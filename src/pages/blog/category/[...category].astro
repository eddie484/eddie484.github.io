---
import { BLOG_TITLE } from '../../../config/blog';
import { UI } from '../../../i18n/ui';
import RedirectPage from '../../../layouts/RedirectPage.astro';
import { FLAT_CATEGORIES, getCategoryUrl } from '../../../lib/blog';

// 언어 분리 이전의 /blog/category/... URL을 /ko/blog/category/...로 넘긴다.
export function getStaticPaths() {
	return FLAT_CATEGORIES.map((category) => ({
		params: { category: category.path.join('/') },
		props: { to: getCategoryUrl(category, 'ko'), label: category.label },
	}));
}

const { to, label } = Astro.props;
---

<RedirectPage to={to} title={`${label} | ${BLOG_TITLE.ko}`} message={UI.ko.goToBlog} />
