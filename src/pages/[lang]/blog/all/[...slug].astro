---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { UI } from '../../../../i18n/ui';
import BlogLayout from '../../../../layouts/BlogLayout.astro';
import {
	findTranslation,
	getAllPostUrl,
	getPostLang,
	getPostSlug,
	getPostsByLang,
	sortPosts,
} from '../../../../lib/blog';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { lang: getPostLang(post), slug: getPostSlug(post) },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const currentPost = Astro.props;
const lang = getPostLang(currentPost);
const collection = await getCollection('blog');
const allPosts = sortPosts(getPostsByLang(collection, lang));
const translation = findTranslation(collection, currentPost);
const { Content } = await render(currentPost);
---

<BlogLayout
	allPosts={allPosts}
	scopePosts={allPosts}
	scopeTitle={UI[lang].allPosts}
	currentPost={currentPost}
	postLinkScope="all"
	content={Content}
	lang={lang}
	translationUrl={translation ? getAllPostUrl(translation) : undefined}
/>
