---
import BaseHead from '../components/BaseHead.astro';
import BlogHeader from '../components/BlogHeader.astro';
import CategorySidebar from '../components/CategorySidebar.astro';
import PostArticle from '../components/PostArticle.astro';
import PostFooterList from '../components/PostFooterList.astro';
import PostListPanel from '../components/PostListPanel.astro';
import { BLOG_DESCRIPTION, BLOG_TITLE } from '../config/blog';
import { DEFAULT_LANG, UI, type Lang } from '../i18n/ui';
import { getCategoryById, getCategoryUrl, type BlogPost } from '../lib/blog';

interface Props {
	allPosts: BlogPost[];
	scopePosts: BlogPost[];
	scopeTitle: string;
	currentPost?: BlogPost;
	activeCategoryId?: string;
	postLinkScope?: 'default' | 'all';
	content?: any;
	lang?: Lang;
	// 내용이 대응되는 반대 언어 페이지 경로. 언어 토글과 hreflang에 쓴다.
	translationUrl?: string;
}

const {
	allPosts,
	scopePosts,
	scopeTitle,
	currentPost,
	activeCategoryId,
	postLinkScope = 'default',
	content: Content,
	lang = DEFAULT_LANG,
	translationUrl,
} = Astro.props;
const t = UI[lang];
const pageTitle = currentPost ? `${currentPost.data.title} | ${BLOG_TITLE[lang]}` : BLOG_TITLE[lang];
const pageDescription = currentPost?.data.description ?? BLOG_DESCRIPTION[lang];
const activeCategory = activeCategoryId ? getCategoryById(activeCategoryId) : undefined;
const scopeHref = activeCategory ? getCategoryUrl(activeCategory, lang) : `/${lang}/blog/`;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={pageTitle}
			description={pageDescription}
			lang={lang}
			translationUrl={translationUrl}
		/>
	</head>
	<body>
		<BlogHeader lang={lang} altUrl={translationUrl} />
		<main class="blog-shell">
			<CategorySidebar posts={allPosts} activeCategoryId={activeCategoryId} lang={lang} />
			<section class="blog-content" aria-label={t.postAreaAria}>
				<PostListPanel
					posts={scopePosts}
					scopeTitle={scopeTitle}
					currentPostId={currentPost?.id}
					postLinkScope={postLinkScope}
					lang={lang}
				/>
				{
					currentPost && Content ? (
						<>
							<PostArticle post={currentPost} lang={lang}>
								<Content />
							</PostArticle>
							<PostFooterList
								posts={scopePosts}
								currentPost={currentPost}
								scopeTitle={scopeTitle}
								scopeHref={scopeHref}
								postLinkScope={postLinkScope}
								lang={lang}
							/>
						</>
					) : (
						<div class="empty-post">
							<h1>{scopeTitle}</h1>
							<p>{t.emptyScope}</p>
						</div>
					)
				}
			</section>
		</main>
	</body>
</html>

<style>
	.blog-shell {
		display: flex;
		gap: var(--layout-gap);
		width: var(--site-width);
		min-width: var(--site-width);
		margin: 22px auto 80px;
		align-items: flex-start;
	}

	.blog-content {
		width: var(--content-width);
		flex: 0 0 var(--content-width);
		padding: 34px 36px 54px;
		border: 1px solid var(--line);
		background: var(--surface);
	}

	.empty-post {
		padding: 40px 0;
		color: var(--muted);
		font-size: 14px;
	}

	.empty-post h1 {
		margin: 0 0 10px;
		color: var(--ink);
		font-size: 24px;
	}
</style>
